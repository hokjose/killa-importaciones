---
import Header from "../components/Header.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

// Extraemos la propiedad showNavbar, por defecto es true
const { showNavbar = true } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Artesanías Killa</title>
  </head>
  <body>
    <Header />

    {showNavbar && <Navbar />}
    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
