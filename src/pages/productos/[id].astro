---
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const productos = [
    {
      id: "poncho-andino-premium",
      nombre: "Poncho Andino Premium",
      precio: 250,
      categoria: "ROPA DE ALPACA",
      imagen: "/images/poncho_andino.png",
      descripcion:
        "Poncho artesanal elaborado con fibra de alpaca premium. Ideal para climas frios y ocasiones especiales.",
    },

    {
      id: "cartera-de-cuero-repujado",
      nombre: "Cartera de Cuero Repujado",
      precio: 180,
      categoria: "CARTERAS Y CUERO",
      imagen: "/images/cartera_cuero.png",
      descripcion:
        "Cartera artesanal de cuero repujado con acabados elegantes y diseño peruano.",
    },

    {
      id: "chullo-tradicional-cusqueño",
      nombre: "Chullo Tradicional Cusqueño",
      precio: 45,
      categoria: "ACCESORIOS",
      imagen: "/images/chullo_tradicional.png",
      descripcion:
        "Chullo de lana de oveja con orejeras. Colores vivos y diseño originario.",
    },

    {
      id: "chalina-de-alpaca-solida",
      nombre: "Chalina de Alpaca Sólida",
      precio: 85,
      categoria: "ROPA DE ALPACA",
      imagen: "/images/chalina_de_alpaca.png",
      descripcion:
        "Chalina elegante de alpaca suave y cálida. Perfecta para invierno.",
    },

    {
      id: "morral-viajero",
      nombre: "Morral Viajero",
      precio: 120,
      categoria: "CARTERAS Y CUERO",
      imagen: "/images/morral_viajero.png",
      descripcion:
        "Morral resistente para viajes y uso diario con estilo artesanal.",
    },

    {
      id: "pulsera-de-macrame",
      nombre: "Pulsera de Macramé",
      precio: 15,
      categoria: "ACCESORIOS",
      imagen: "/images/pulzera_de_macrame.png",
      descripcion:
        "Pulsera artesanal tejida a mano con diseños modernos y tradicionales.",
    },
  ];

  return productos.map((p) => ({
    params: { id: p.id },
    props: { producto: p },
  }));
}

const { producto } = Astro.props;
---

<MainLayout showNavbar={false}>
  <div class="contenedor-general">
    <a href="/catalogo" class="volver"> ← Volver al catálogo </a>

    <div class="container-detalle">
      <div class="foto">
        <img src={producto.imagen} alt={producto.nombre} />
      </div>

      <div class="info">
        <p class="categoria">{producto.categoria}</p>

        <h1>{producto.nombre}</h1>

        <h2 class="precio">S/ {producto.precio}.00</h2>

        <h3>Descripción del producto</h3>
        <p class="descipcion">{producto.descripcion}</p>
      </div>

      <a
        href={`https://wa.me/974357754?text=Hola,%20quiero%20más%20información%20sobre%20${producto.nombre}`}
        target="_blank"
        class="btn-whatsapp"
      >
        Consultar por WhatsApp
      </a>
    </div>
  </div>
</MainLayout>

<style>
  body {
    background: #f5f5f5;
  }

  .contenedor-general {
    max-width: 1250px;
    margin: auto;
    padding: 30px;
  }

  .volver {
    display: inline-block;
    margin-bottom: 20px;
    text-decoration: none;
    color: #777;
    font-weight: 600;
    transition: 0.3s;
  }

  .volver:hover {
    color: #222;
  }

  .container-detalle {
    background: white;
    border-radius: 30px;
    padding: 50px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
  }

  .foto {
    background: #f7f7f7;
    border-radius: 25px;
    padding: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 500px;
  }

  .foto img {
    width: 100%;
    max-width: 420px;
    object-fit: contain;
  }

  .categoria {
    font-size: 13px;
    font-weight: bold;
    letter-spacing: 1px;
    color: #666;
    margin-bottom: 15px;
  }

  h1 {
    font-size: 52px;
    line-height: 1.1;
    color: #222;
    margin-bottom: 20px;
  }

  .precio {
    font-size: 42px;
    color: #22c55e;
    margin-bottom: 35px;
  }

  .descripcion {
    margin-bottom: 30px;
  }

  .descripcion h3 {
    font-size: 22px;
    margin-bottom: 12px;
    color: #222;
  }

  .descripcion p {
    color: #666;
    line-height: 1.8;
    font-size: 17px;
  }

  .caracteristicas {
    margin-bottom: 35px;
  }

  .caracteristicas h3 {
    font-size: 22px;
    margin-bottom: 15px;
    color: #222;
  }

  .caracteristicas ul {
    padding-left: 20px;
  }

  .caracteristicas li {
    margin-bottom: 12px;
    color: #555;
    font-size: 16px;
  }

  .btn-whatsapp {
    display: block;
    width: 100%;
    text-align: center;
    background: #22c55e;
    color: white;
    padding: 18px;
    border-radius: 16px;
    text-decoration: none;
    font-size: 18px;
    font-weight: bold;
    transition: 0.3s;
  }

  .btn-whatsapp:hover {
    background: #16a34a;
    transform: translateY(-3px);
  }

  @media (max-width: 900px) {
    .container-detalle {
      grid-template-columns: 1fr;
      padding: 25px;
    }

    h1 {
      font-size: 38px;
    }

    .precio {
      font-size: 30px;
    }

    .foto {
      min-height: auto;
    }
  }
</style>
