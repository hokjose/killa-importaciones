---
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const productos = [
    {
      id: "poncho-andino-premium",
      nombre: "Poncho Andino Premium",
      precio: 250,
      categoria: "ROPA DE ALPACA",
      imagen: "/images/poncho_andino.png",
      descripcion:
        "Poncho artesanal elaborado con fibra de alpaca premium. Ideal para climas frios y ocasiones especiales.",
    },

    {
      id: "cartera-de-cuero-repujado",
      nombre: "Cartera de Cuero Repujado",
      precio: 180,
      categoria: "CARTERAS Y CUERO",
      imagen: "/images/cartera_cuero.png",
      descripcion:
        "Cartera artesanal de cuero repujado con acabados elegantes y diseño peruano.",
    },

    {
      id: "chullo-tradicional-cusqueño",
      nombre: "Chullo Tradicional Cusqueño",
      precio: 45,
      categoria: "ACCESORIOS",
      imagen: "/images/chullo_tradicional.png",
      descripcion:
        "Chullo de lana de oveja con orejeras. Colores vivos y diseño originario.",
    },

    {
      id: "chalina-de-alpaca-solida",
      nombre: "Chalina de Alpaca Sólida",
      precio: 85,
      categoria: "ROPA DE ALPACA",
      imagen: "/images/chalina_de_alpaca.png",
      descripcion:
        "Chalina elegante de alpaca suave y cálida. Perfecta para invierno.",
    },

    {
      id: "morral-viajero",
      nombre: "Morral Viajero",
      precio: 120,
      categoria: "CARTERAS Y CUERO",
      imagen: "/images/morral_viajero.png",
      descripcion:
        "Morral resistente para viajes y uso diario con estilo artesanal.",
    },

    {
      id: "pulsera-de-macrame",
      nombre: "Pulsera de Macramé",
      precio: 15,
      categoria: "ACCESORIOS",
      imagen: "/images/pulzera_de_macrame.png",
      descripcion:
        "Pulsera artesanal tejida a mano con diseños modernos y tradicionales.",
    },
  ];

  return productos.map((p) => ({
    params: { id: p.id },
    props: { producto: p },
  }));
}

const { producto } = Astro.props;
---

<MainLayout showNavbar={false}>
  <div class="contenedor-general">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <a href="/catalogo" class="volver"> ← Volver al catálogo </a>

    <div class="container-detalle">
      <div class="foto">
        <img src={producto.imagen} alt={producto.nombre} />
      </div>

      <div class="info">
        <p class="categoria">{producto.categoria}</p>

        <h1>{producto.nombre}</h1>

        <h2 class="precio">S/ {producto.precio}.00</h2>

        <h3>Descripción del producto</h3>
        <p class="descipcion">{producto.descripcion}</p>
      </div>

      <a
        href={`https://wa.me/974357754?text=Hola,%20quiero%20más%20información%20sobre%20${producto.nombre}`}
        target="_blank"
        class="btn-whatsapp"
      >
        Consultar por WhatsApp
      </a>
    </div>
  </div>
</MainLayout>

<style>
  body {
    background: linear-gradient(180deg, #f8fafc, #eef2f7);
  }

  .contenedor-general {
    max-width: 1300px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  /* BOTÓN VOLVER */

  .volver {
    display: inline-flex;
    align-items: center;
    gap: 8px;

    text-decoration: none;

    color: #475569;

    font-weight: 700;

    margin-bottom: 25px;

    transition: 0.3s;
  }

  .volver:hover {
    color: #2563eb;

    transform: translateX(-4px);
  }

  /* CONTENEDOR PRINCIPAL */

  .container-detalle {
    background: white;

    border-radius: 32px;

    padding: 50px;

    display: grid;

    grid-template-columns: 1fr 1fr;

    gap: 60px;

    align-items: center;

    border: 1px solid #e2e8f0;

    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
  }

  /* IMAGEN */

  .foto {
    background:
      radial-gradient(circle at top, rgba(59, 130, 246, 0.08), transparent 60%),
      #f8fafc;

    border-radius: 28px;

    padding: 50px;

    display: flex;
    justify-content: center;
    align-items: center;

    min-height: 520px;

    border: 1px solid #e2e8f0;
  }

  .foto img {
    width: 100%;

    max-width: 450px;

    object-fit: contain;

    transition: 0.4s ease;
  }

  .foto:hover img {
    transform: scale(1.05);
  }

  /* INFO */

  .categoria {
    display: inline-block;

    background: #dbeafe;

    color: #2563eb;

    padding: 8px 16px;

    border-radius: 999px;

    font-size: 12px;

    font-weight: 800;

    letter-spacing: 1px;

    margin-bottom: 20px;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);

    font-weight: 900;

    line-height: 1.1;

    color: #0f172a;

    margin-bottom: 20px;
  }

  .precio {
    font-size: clamp(2rem, 4vw, 3rem);

    color: #16a34a;

    font-weight: 900;

    margin-bottom: 30px;
  }

  .info h3 {
    font-size: 1.3rem;

    color: #0f172a;

    margin-bottom: 15px;
  }

  .descipcion {
    color: #64748b;

    font-size: 1.05rem;

    line-height: 1.9;

    margin-bottom: 35px;
  }

  /* BOTÓN WHATSAPP */

  .btn-whatsapp {
    display: inline-flex;

    justify-content: center;
    align-items: center;

    width: 100%;

    padding: 18px;

    text-decoration: none;

    border-radius: 18px;

    font-size: 1rem;

    font-weight: 800;

    color: white;

    background: linear-gradient(135deg, #16a34a, #22c55e);

    box-shadow: 0 12px 25px rgba(34, 197, 94, 0.25);

    transition: 0.3s ease;
  }

  .btn-whatsapp:hover {
    transform: translateY(-4px);

    box-shadow: 0 18px 35px rgba(34, 197, 94, 0.35);
  }

  /* RESPONSIVE */

  @media (max-width: 900px) {
    .container-detalle {
      grid-template-columns: 1fr;

      gap: 35px;

      padding: 25px;
    }

    .foto {
      min-height: auto;

      padding: 30px;
    }

    h1 {
      text-align: center;
    }

    .categoria {
      display: block;

      width: fit-content;

      margin-left: auto;
      margin-right: auto;
    }

    .precio {
      text-align: center;
    }

    .info h3 {
      text-align: center;
    }

    .descipcion {
      text-align: center;
    }
  }
</style>
