---
import MainLayout from "../pages/productos_id.astro";

// 1. Esta función le dice a Astro qué páginas crear
export async function getStaticPaths() {
  const productos = [
    {
      id: "poncho-andino-premium",
      nombre: "poncho Andino Premium",
      precio: 250,
      categoria: "ROPA DE ALPACA",
      imagen: "/images/poncho_andino.png",
    },
    {
      id: "cartera-de-cuero-repujado",
      nombre: "cartera de cuero repujado",
      precio: 180,
      categoria: "ROPA DE ALPACA",
      imagen: "/images/cartera_cuero.png",
    },
    {
      id: "chullo-tradicional-cusqueño",
      nombre: "chullo tradicional cusqueño",
      precio: 45,
      categoria: "CARTERAS Y CUERO",
      imagen: "/images/chullo_tradicional.png",
    },
    {
      id: "chalina-de-alpaca-solida",
      nombre: "chalina de alpaca solida",
      precio: 85,
      categoria: "CARTERAS Y CUERO",
      imagen: "/images/chalina_de_alpaca.png",
    },
    {
      id: "morral-viajero",
      nombre: "morral viajero",
      precio: 120,
      categoria: "CARTERAS Y CUERO",
      imagen: "/images/morral_viajero.png",
    },
    {
      id: "pulsera-de-macrame",
      nombre: "pulsera de macrame",
      precio: 15,
      categoria: "ACCESORIOS",
      imagen: "/images/pulzera_de_macrame.png",
    },
  ];

  return productos.map((p) => ({
    params: { id: p.id },
    props: { producto: p },
  }));
}

const { producto } = Astro.props;
---

<MainLayout showNavbar={false}>
  <div class="container-detalle">
    <div class="foto">
      <img src={producto.imagen} alt={producto.nombre} />
    </div>

    <div class="info">
      <span class="categoria-tag">{producto.categoria}</span>
      <h1>{producto.nombre}</h1>
      <p class="precio">S/ {producto.precio.toFixed(2)}</p>

      <div class="detalles">
        <h3>Descripción</h3>
        <p>
          Esta es una pieza auténtica de <strong>Artesanías Killa</strong>,
          elaborada con técnicas ancestrales y materiales de la mejor calidad de
          la región.
        </p>
        <ul>
          <li>✨ 100% Hecho a mano</li>
          <li>🌱 Tintes naturales</li>
          <li>🏔️ Origen: Cusco, Perú</li>
        </ul>
      </div>

      <button
        class="btn-comprar"
        onclick="alert('Redirigiendo a WhatsApp para el pedido...')"
      >
        Comprar ahora 🛒
      </button>

      <a href="/catalogo" class="volver">⬅ Volver al catálogo</a>
    </div>
  </div>
</MainLayout>

<style>
  .container-detalle {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    padding: 3rem 1rem;
    max-width: 1100px;
    margin: 0 auto;
    align-items: center;
  }

  .foto img {
    width: 100%;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .info h1 {
    font-size: 2.5rem;
    margin: 0.5rem 0;
    text-transform: capitalize;
  }

  .categoria-tag {
    background: #f0f0f0;
    padding: 5px 12px;
    border-radius: 15px;
    font-size: 0.8rem;
    font-weight: bold;
    color: #555;
  }

  .precio {
    font-size: 2rem;
    color: #00b341;
    font-weight: bold;
    margin: 1rem 0;
  }

  .detalles {
    margin: 2rem 0;
    line-height: 1.6;
  }

  .btn-comprar {
    background: #111;
    color: white;
    border: none;
    padding: 1.2rem;
    width: 100%;
    border-radius: 12px;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s;
  }

  .btn-comprar:hover {
    background: #00b341;
  }

  .volver {
    display: block;
    text-align: center;
    margin-top: 1.5rem;
    text-decoration: none;
    color: #666;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .container-detalle {
      grid-template-columns: 1fr;
    }
  }
</style>
