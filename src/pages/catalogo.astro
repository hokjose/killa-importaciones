---
import MainLayout from "../layouts/MainLayout.astro";

const productos = [
  {
    nombre: "poncho Andino Premium",
    precio: 250.0,
    categoria: "ROPA DE ALPACA",
    imagen: "/images/poncho_andino.png",
  },

  {
    nombre: "cartera de cuero repujado",
    precio: 180.0,
    categoria: "ROPA DE ALPACA",
    imagen: "/images/cartera_cuero.png",
  },

  {
    nombre: "chullo tradicional cusqueño",
    precio: 45.0,
    categoria: "CARTERAS Y CUERO",
    imagen: "/images/chullo_nuevo.png",
  },
  {
    nombre: "chalina de alpaca solida",
    precio: 85.0,
    categoria: "CARTERAS Y CUERO",
    imagen: "/images/chalina_de_alpaca.png",
  },
  {
    nombre: "morral viajero",
    precio: 120.0,
    categoria: "CARTERAS Y CUERO",
    imagen: "/images/morral_viajero.png",
  },
  {
    nombre: "pulsera de macrame",
    precio: 15.0,
    categoria: "ACCESORIOS",
    imagen: "/images/pulzera_de_macrame.png",
  },
];
---

<MainLayout showNavbar={false}>
  <h2>Nuestro Catálogo</h2>

  <h4 class="cata">Explora nuestros catálogos principales</h4>

  <div class="topbar">
    <div class="search-box">
      <span>🔍</span>
      <input
        type="text"
        id="input-busqueda"
        placeholder="Buscar productos..."
      />
    </div>

    <div class="categorias">
      <button class="btn-filtro activo" data-categoria="todos"> Todos </button>
      <button class="btn-filtro" data-categoria="ROPA DE ALPACA"
        >Ropa de Alpaca</button
      >
      <button class="btn-filtro" data-categoria="CARTERAS Y CUERO"
        >Carteras y Cuero</button
      >
      <button class="btn-filtro" data-categoria="ACCESORIOS">Accesorios</button>
    </div>
  </div>

  <div class="grid">
    {
      productos.map((p) => {
        // Usamos el mismo ID que pusimos arriba
        const productoId = p.nombre.toLowerCase().replace(/\s+/g, "-");

        return (
          /* La ruta ahora es /productos/ seguido del id */
          <a href={`/productos/${productoId}`} class="card-link">
            <div class="card" data-categoria={p.categoria}>
              <span class="categoria">{p.categoria}</span>
              <img src={p.imagen} alt={p.nombre} />
              <div class="contenido">
                <h3>{p.nombre}</h3>
                <div class="footer">
                  <p>S/ {p.precio.toFixed(2)}</p>
                  <button class="btn-carrito">🛒</button>
                </div>
              </div>
            </div>
          </a>
        );
      })
    }
  </div>

  <button class="btn-volver" onclick="window.location.href='/'">
    ⬅ Volver al inicio
  </button>

  <br />
  <br />
  <br />
</MainLayout>

<style>
  * {
    box-sizing: border-box;
  }

  body {
    background: #f8fafc;
  }

  h2 {
    text-align: center;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 900;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }

  .cata {
    text-align: center;
    color: #64748b;
    font-size: 1rem;
    margin-bottom: 2rem;
  }

  /* BUSCADOR Y FILTROS */

  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;

    flex-wrap: wrap;

    gap: 1.5rem;

    margin-bottom: 2.5rem;
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 12px;

    flex: 1;
    min-width: 280px;
    max-width: 450px;

    background: white;

    border: 1px solid #e2e8f0;

    padding: 1rem 1.2rem;

    border-radius: 18px;

    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
  }

  .search-box input {
    width: 100%;

    border: none;
    outline: none;

    font-size: 1rem;

    background: transparent;
  }

  .categorias {
    display: flex;
    gap: 0.8rem;

    flex-wrap: wrap;
  }

  .categorias button {
    border: none;

    padding: 12px 20px;

    border-radius: 999px;

    cursor: pointer;

    font-weight: 600;

    background: white;

    color: #334155;

    border: 1px solid #e2e8f0;

    transition: 0.3s;
  }

  .categorias button:hover {
    transform: translateY(-2px);

    border-color: #3b82f6;
  }

  .categorias .activo {
    background: linear-gradient(135deg, #2563eb, #3b82f6);

    color: white;

    border-color: transparent;

    box-shadow: 0 10px 20px rgba(37, 99, 235, 0.25);
  }

  /* GRID */

  .grid {
    display: grid;

    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));

    gap: 2rem;

    margin-top: 2rem;
  }

  /* LINK */

  .card-link {
    text-decoration: none;
    color: inherit;
  }

  /* TARJETAS */

  .card {
    background: white;

    border-radius: 24px;

    overflow: hidden;

    position: relative;

    border: 1px solid #e2e8f0;

    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);

    transition: all 0.35s ease;

    cursor: pointer;
  }

  .card:hover {
    transform: translateY(-10px);

    box-shadow: 0 25px 45px rgba(15, 23, 42, 0.15);

    border-color: #3b82f6;
  }

  .card img {
    width: 100%;
    height: 240px;

    object-fit: cover;

    transition: 0.4s ease;
  }

  .card:hover img {
    transform: scale(1.05);
  }

  .categoria {
    position: absolute;

    top: 14px;
    left: 14px;

    background: rgba(255, 255, 255, 0.95);

    color: #0f172a;

    padding: 8px 14px;

    border-radius: 999px;

    font-size: 11px;

    font-weight: 700;

    letter-spacing: 0.5px;

    backdrop-filter: blur(10px);

    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
  }

  .contenido {
    padding: 1.2rem;
  }

  .contenido h3 {
    color: #0f172a;

    font-size: 1rem;

    font-weight: 700;

    line-height: 1.5;

    margin-bottom: 1rem;

    text-transform: capitalize;
  }

  .footer {
    display: flex;

    justify-content: space-between;

    align-items: center;
  }

  .footer p {
    color: #16a34a;

    font-size: 1.25rem;

    font-weight: 800;

    margin: 0;
  }

  .btn-carrito {
    width: 48px;
    height: 48px;

    border: none;

    border-radius: 14px;

    background: #f1f5f9;

    cursor: pointer;

    transition: 0.3s ease;

    font-size: 1.1rem;
  }

  .btn-carrito:hover {
    background: #2563eb;

    color: white;

    transform: scale(1.08);
  }

  /* BOTÓN VOLVER */

  .btn-volver {
    display: block;

    margin: 3rem auto 0;

    padding: 14px 28px;

    border: none;

    border-radius: 999px;

    background: linear-gradient(135deg, #0f172a, #1e293b);

    color: white;

    font-weight: 700;

    cursor: pointer;

    transition: 0.3s;
  }

  .btn-volver:hover {
    transform: translateY(-3px);

    box-shadow: 0 15px 30px rgba(15, 23, 42, 0.25);
  }

  /* RESPONSIVE */

  @media (max-width: 768px) {
    .topbar {
      flex-direction: column;
      align-items: stretch;
    }

    .search-box {
      max-width: 100%;
    }

    .categorias {
      justify-content: center;
    }

    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const botones = document.querySelectorAll(".btn-filtro");
  const tarjetas = document.querySelectorAll<HTMLElement>(".card");

  botones.forEach((boton) => {
    boton.addEventListener("click", () => {
      // quitar activo
      botones.forEach((b) => b.classList.remove("activo"));
      boton.classList.add("activo");

      const filtro = boton.getAttribute("data-categoria");

      // mostrar/ocultar tarjetas
      tarjetas.forEach((tarjeta) => {
        const categoriaTarjeta = tarjeta.getAttribute("data-categoria");

        if (filtro === "todos" || filtro === categoriaTarjeta) {
          tarjeta.style.display = "block";
        } else {
          tarjeta.style.display = "none";
        }
      });
    });
  });
</script>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const buscador = document.getElementById("input-busqueda");
    const botones = document.querySelectorAll(".btn-filtro");
    const tarjetas = document.querySelectorAll(".card");

    // Función principal de filtrado
    function filtrarProductos() {
      const texto = buscador.value.toLowerCase(); // Lo que escribió el usuario
      const botonActivo = document.querySelector(".btn-filtro.activo");
      const categoriaFiltro = botonActivo.getAttribute("data-categoria");

      tarjetas.forEach((tarjeta) => {
        const nombreProducto = tarjeta
          .querySelector("h3")
          .textContent.toLowerCase();
        const categoriaProducto = tarjeta.getAttribute("data-categoria");

        // Condición 1: ¿Coincide el texto buscado?
        const coincideTexto = nombreProducto.includes(texto);

        // Condición 2: ¿Coincide la categoría?
        const coincideCategoria =
          categoriaFiltro === "todos" || categoriaFiltro === categoriaProducto;

        // Si cumple AMBAS, se muestra, si no, se esconde
        if (coincideTexto && coincideCategoria) {
          tarjeta.style.display = "block";
        } else {
          tarjeta.style.display = "none";
        }
      });
    }

    // Escuchar cuando el usuario escribe en el buscador
    buscador.addEventListener("input", filtrarProductos);

    // Escuchar cuando el usuario hace clic en los botones
    botones.forEach((boton) => {
      boton.addEventListener("click", () => {
        botones.forEach((b) => b.classList.remove("activo"));
        boton.classList.add("activo");
        filtrarProductos(); // Volver a filtrar al cambiar categoría
      });
    });
  });
</script>
